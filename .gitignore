# ==========================================
# Xcode / iOS / macOS Project Gitignore
# ==========================================

## System Files
.DS_Store
**/.DS_Store

## User Settings and Workspace State
## (Prevents personal layout/state tracking)
xcuserdata/
*.xcuserstate
*.xcuserdatad

## Xcode Build Artifacts
DerivedData/
.build/
*.hmap

## App Packaging & Crash Logs
*.ipa
*.dSYM.zip
*.dSYM

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# ==========================================
# Dependency Managers
# ==========================================

## Swift Package Manager
## (Uncomment Packages/ if you want to completely ignore local package source code)
# Packages/
.swiftpm/
Package.resolved

## CocoaPods
## (Uncomment Pods/ if you prefer not to commit your third-party source code)
# Pods/
# *.xcworkspace

## Carthage
Carthage/Build/
# Carthage/Checkouts

# ==========================================
# Automation & CI/CD (fastlane)
# ==========================================
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ==========================================
# Security & Secrets
# ==========================================
Secrets.plist
**/Secrets.plist
**/.DS_Store
